#:kivy 2.3.1

<MainScreen>:
    FitImage:
        source: "assets/images/back1.jpg"
    MDBoxLayout:
        orientation: 'vertical'
        padding: '50dp'
        spacing: '30dp'

        MDIconButton:
            icon: 'cog'
            pos_hint: {"right": 1, "top": 1}
            icon_size: '50dp'

        MDLabel:
            text: "SHOOTER"
            halign: 'center'
            font_size: '60sp'

        Image:
            source: 'assets/images/rocket.png'
            size_hint_y: 0.7
            allow_stretch: True
        MDRectangleFlatButton:
            text: 'PLAY'
            font_size: '60sp'
            pos_hint: {'center_x': 0.5, 'center_y': 0.5}
            on_press: root.manager.current = "game"

<Ship@Image>:
    source: 'assets/images/rocket.png'
    size_hint: (None, None)
    size: dp(100), dp(250)

<GameScreen>:
    FloatLayout:
        FloatLayout:
            id: game
            FloatLayout:
                id: back
                FitImage:
                    source: "assets/images/back.jpg"
            FloatLayout:
                id: front
                Ship:
                    id: ship
                    center: root.center
        FloatLayout:
            id: interface
            MDBoxLayout:
                spacing: dp(20)
                padding: dp(20)
                MDFloatingActionButton:
                    icon: 'arrow-left-bold'
                    on_press: root.pressKey("left")
                    on_release: root.releaseKey("left")
                MDFloatingActionButton:
                    icon: 'arrow-right-bold'
                    on_press: root.pressKey("right")
                    on_release: root.releaseKey("right")
                Widget:
                
                MDFloatingActionButton:
                    icon: 'arrow-up-bold'
                    on_press: root.pressKey("shot")
                    on_release: root.releaseKey("shot")
            
            MDIconButton:
                icon: 'pause'
                pos_hint: {"top": 1, "right": 1}
                icon_size: '50dp'
                on_press: root.make_pause()
                

<Shot>:
    size_hint: None, None
    size: 20, 20
    md_bg_color: app.theme_cls.primary_color
                    
<Enemy@Image>:
    source: "assets/images/enemy.png"
    size_hint: None, None
    size: dp(50), dp(50)


        

