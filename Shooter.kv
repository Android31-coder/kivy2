#:kivy 2.3.1

<MainScreen>:
    MDBoxLayout:
        orientation: 'vertical'
        padding: '50pd'
        spacing: '30sp'

        MDIconButton:
            icon: 'cog'
            pos_hint: {"right": 1, "top": 1}
            icon_size: '50dp'

        MDLabel:
            text: 'SHOOTER'
            halign: 'center'
            font_size: '60sp'

        Image:
            source: 'assets/images/bibizyanu.jpg'
            size_hint_y: 0.7
            allow_stretch: True

        MDRectangleFlatButton:
            text: 'PLAY'
            font_size: '60sp'
            pos_hint: {'center_x': 0.5, 'center_y': 0.5}
            on_press: root.manager.current = 'game'

<Ship@Image>:
    source: ''
    size_hint: (None, None)
    size: dp(100), dp(250)

<GameScreen>:
    FloatLayout:
        FloatLayout:
            id: game
            FloatLayout:
                id: back
            FloatLayout:
                id: front
                Ship:
                    id: ship
                    center: root.center
        FloatLayout:
            id: interface
            MDBoxLayout:
                spacing: dp(20)
                padding: dp(20)
                MDFloatingActionButton:
                    icon: 'arrow-left-bold'
                    on_press: root.pressKey('left')
                    on_release: root.releaseKey('left')

                MDFloatingActionButton:
                    icon: 'arrow-right-bold'
                    on_press: root.pressKey('right')
                    on_release: root.releaseKey('right')
                Widget:
                    