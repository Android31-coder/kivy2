#:kivy 2.3.1

<MainScreen>:
    FitImage:
        source: "assets/images/back1.jpg"
    MDBoxLayout:
        orientation: 'vertical'
        padding: '50dp'
        spacing: '30dp'

        MDIconButton:
            icon: 'cog'
            pos_hint: {"right": 1, "top": 1}
            icon_size: '50dp'
            on_press: root.manager.current = "sett"

        MDLabel:
            text: "SHOOTER"
            halign: 'center'
            font_size: '60sp'

        MDLabel:
            id: record_label
            text: "RECORD: 0"
            halign: 'center'
            font_size:"30sp"

        Image:
            source: 'assets/images/rocket1.png'
            size_hint_y: 0.7
            allow_stretch: True
        MDRectangleFlatButton:
            text: 'PLAY'
            font_size: '60sp'
            pos_hint: {'center_x': 0.5, 'center_y': 0.5}
            on_press: root.manager.current = "game"

<Ship@Image>:
    source: 'assets/images/rocket1.png'
    size_hint: (None, None)
    size: dp(100), dp(250)

<GameScreen>:
    FloatLayout:
        FloatLayout:
            id: game
            FloatLayout:
                id: back
                FitImage:
                    source: "assets/images/back.jpg"
            FloatLayout:
                id: front
                Ship:
                    id: ship
                    center: root.center
        FloatLayout:
            id: interface
            MDBoxLayout:
                spacing: dp(20)
                padding: dp(20)
                MDFloatingActionButton:
                    icon: 'arrow-left-bold'
                    on_press: root.pressKey("left")
                    on_release: root.releaseKey("left")
                MDFloatingActionButton:
                    icon: 'arrow-right-bold'
                    on_press: root.pressKey("right")
                    on_release: root.releaseKey("right")
                Widget:
                
                MDFloatingActionButton:
                    icon: 'arrow-up-bold'
                    on_press: root.pressKey("shot")
                    on_release: root.releaseKey("shot")
            
            MDIconButton:
                icon: 'pause'
                pos_hint: {"top": 1, "right": 1}
                icon_size: '50dp'
                on_press: root.make_pause()
            MDLabel:
                id: lives_label
                text: "Життя: 3"
                pos_hint: {"x": 0.02, "top": 0.80}
                size_hint: None, None
                size: self.texture_size
                text_size: None, None
                halign: 'left'
                font_size: "20sp"

            MDLabel:
                id: score_label
                text: "Збито: 0"
                pos_hint: {"right": 0.98, "top": 0.80}
                size_hint: None, None
                size: self.texture_size
                text_size: None, None
                halign: 'right'
                font_size: "20sp"

        FloatLayout:
            id: overlay
            opacity: 0
            canvas:
                Color:
                    rgba: 0, 0, 0, 0.5
                Rectangle:
                    size: self.size
                    pos: self.pos
            MDBoxLayout:
                orientation: 'vertical'
                size_hint: 0.8 , 0.6
                pos_hint: {"center_x": 0.5, "center_y": 0.5}
                padding: dp(33)
                spacing: dp(20)
                MDLabel:
                    id: final_score
                    text: "Збито  ворогів: 0"
                    halign: 'center'
                    font_size: "35sp"
                MDLabel:
                    id: final_high_score
                    text: 'Рекорд: 0'
                    halign: 'center'
                    font_size: '30sp'
                MDRectangleFlatButton:
                    text: 'RESTART'
                    font_size: "30sp"
                    on_press: root.restart_game()
                    pos_hint: {"center_x": 0.5}


                

<Shot>:
    size_hint: None, None
    size: 20, 20
    md_bg_color: app.theme_cls.primary_color
                    
<Enemy@Image>:
    source: "enemy.png"
    size_hint: None, None
    size: dp(50), dp(50)

<SettingsScreen>:
    FitImage:
        source: "assets/images/back1.jpg"
    MDBoxLayout:
        orientation: 'vertical'
        padding: '50dp'
        spacing: '30dp'
        MDLabel:
            text: "НАЛАШТУВАННЯ"
            halign: 'center'
            font_size: '50sp'
        MDLabel:
            text: "Оберіть скін ракети:"
            halign: 'center'
            font_size: '25sp'
        MDRectangleFlatButton:
            text: "Скін 1 (стандарт)"
            on_press: app.set_skin("assets/images/rocket1.png")
        MDRectangleFlatButton:
            text: "Скін 2"
            on_press: app.set_skin("assets/images/rocket1.png")
        MDRectangleFlatButton:
            text: "Скін 3"
            on_press: app.set_skin("rocket2.png")
        MDRectangleFlatButton:
            text: "Повернутися в меню"
            on_press: root.manager.current = "main"